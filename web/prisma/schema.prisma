generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  fcmToken      String?
  role          Role          @default(USER)
  appointments  Appointment[]
  dayBlocks     DayBlock[]
}

model Client {
  id            String          @id @default(cuid())
  name          String
  phone         String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  appointments  Appointment[]
  credits       ClientCredit[]
  creditHistory CreditHistory[]
}

model Service {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  price               Decimal              @db.Decimal(10, 2)
  duration            Int
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  imageUrl            String?
  visible             Boolean              @default(true)
  appointmentServices AppointmentService[]
  clientCredits       ClientCredit[]
  creditHistory       CreditHistory[]
}

model BusinessSettings {
  id                   String   @id @default(cuid())
  onlineBookingEnabled Boolean  @default(false)
  workingHours         Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Appointment {
  id                   String               @id @default(cuid())
  date                 DateTime             @db.Timestamptz(6)
  status               String               @default("PENDING")
  userId               String
  clientId             String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  notificationSent     Boolean              @default(false)
  paidPrice            Decimal?             @db.Decimal(10, 2)
  paymentMethod        PaymentMethod?
  totalDurationMinutes Int?
  whatsappReminderSent Boolean              @default(false)
  client               Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  services             AppointmentService[]
}

model ClientCredit {
  id        String   @id @default(cuid())
  clientId  String
  serviceId String
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([clientId, serviceId])
  @@index([clientId])
  @@index([serviceId])
}

model CreditHistory {
  id        String   @id @default(cuid())
  clientId  String
  serviceId String
  amount    Int
  reason    String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([serviceId])
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  priceSnapshot Decimal     @db.Decimal(10, 2)
  order         Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@index([appointmentId])
  @@index([serviceId])
}

model DayBlock {
  id        String    @id @default(cuid())
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  reason    String?
  blockType BlockType @default(FULL_DAY)
  startTime String?
  endTime   String?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([startDate, endDate])
}

enum Role {
  USER
  ADMIN
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PACKAGE_CREDIT
}

enum BlockType {
  FULL_DAY
  PARTIAL
}
